# Preferred: provide one app origin and let frontend derive:
# - API URL => <origin>/api
# - WebSocket URL => <origin>/ws
NEXT_PUBLIC_APP_ORIGIN=https://todo.flounderboard.com

# Optional explicit overrides:
# NEXT_PUBLIC_API_BASE_URL=https://todo.flounderboard.com/api
# NEXT_PUBLIC_WS_URL=wss://todo.flounderboard.com/ws

# Optional dev-only fallback:
# When set to 1, use mock conversations if the API is unreachable.
# NEXT_PUBLIC_USE_MOCKS=1
